rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - name: string (optional) - The user's display name
    //   - email: string (required) - The user's email address
    //   - company: string (optional) - The user's company name
    //   - subscriptionPlan: string (required, enum) - The user's current plan
    //   - planLevel: number (required, 0-4) - The numeric level of the plan
    //   - usage: map (optional) - Usage tracking data
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'subscriptionPlan', 'planLevel']) &&
             data.uid is string &&
             data.email is string &&
             data.subscriptionPlan in ['FREE', 'STARTER', 'GROWTH', 'PRO', 'ENTERPRISE'] &&
             data.planLevel is number &&
             data.planLevel >= 0 && data.planLevel <= 4 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('company' in data) || (data.company is string && data.company.size() < 100));
    }

    function isAdmin() {
      return isAuthenticated() &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planLevel == 4 ||
              (request.auth.token.email == "mojaffor792@gmail.com" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Only allow creation if the user is the owner and setting default FREE plan (level 0)
      // or if the user is an admin.
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                      (request.resource.data.planLevel == 0 || isAdmin());
      
      // Only allow updates if the user is the owner and planLevel/subscriptionPlan are UNCHANGED
      // (unless they are an admin).
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                      ((request.resource.data.planLevel == resource.data.planLevel && 
                        request.resource.data.subscriptionPlan == resource.data.subscriptionPlan) || 
                       isAdmin());
      
      allow delete: if isAdmin();
    }
  }
}
